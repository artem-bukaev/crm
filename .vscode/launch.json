{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Aspire AppHost",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: solution",
      "program": "${workspaceFolder}/src/Crm.AppHost/bin/Debug/net10.0/Crm.AppHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Crm.AppHost",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:18888"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(http://\\S+)"
      }
    }
  ]
}

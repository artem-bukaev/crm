{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "Crm.slnx"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run: aspire apphost",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/Crm.AppHost",
        "--launch-profile",
        "http"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}

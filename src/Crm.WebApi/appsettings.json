{
  "ConnectionStrings": {
    "CrmDb": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Auth": {
    "Jwt": {
      "SigningKey": "",
      "Issuer": "crm-api",
      "Audience": "crm-clients",
      "ExpiryMinutes": 480
    },
    "SeedAdmin": {
      "Email": "",
      "Password": "",
      "DisplayName": "Administrator"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}

{
  "ConnectionStrings": {
    "CrmDb": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "AgentHeartbeat": {
    "Enabled": true,
    "AgentName": "CRM Heartbeat",
    "WaitingConversationThresholdHours": 4,
    "StaleDealThresholdDays": 7,
    "WaitingConversationsCron": "*/15 * * * *",
    "OverdueTasksCron": "*/15 * * * *",
    "StaleDealsCron": "0 * * * *"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}
